generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Commodity {
  id              Int      @id @default(autoincrement())
  name            String
  unit            String
  lowPrice        Float
  highPrice       Float
  prevailingPrice Float
  region          String?
  sourceDate      DateTime
  createdAt       DateTime @default(now())

  @@unique([name, unit, sourceDate])
  @@index([name, sourceDate])
}

model Recipe {
  id           Int                 @id @default(autoincrement())
  title        String
  url          String              @unique
  imageUrl     String?
  description  String?             @db.Text
  servings     Int?
  prepTime     Int?
  cookTime     Int?
  sourceSite   String              @default("PanlasangPinoy")
  scrapedAt    DateTime            @default(now())
  ingredients  RecipeIngredient[]
  instructions RecipeInstruction[]
}

model RecipeIngredient {
  id       Int    @id @default(autoincrement())
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawText  String
  name     String
  amount   String?
  unit     String?

  @@index([recipeId])
}

model RecipeInstruction {
  id         Int    @id @default(autoincrement())
  recipeId   Int
  recipe     Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stepNumber Int
  text       String @db.Text

  @@unique([recipeId, stepNumber])
}

model NutritionFact {
  id            Int      @id @default(autoincrement())
  foodName      String
  foodCode      String   @unique
  calories      Float?
  protein       Float?
  fat           Float?
  carbohydrates Float?
  fiber         Float?
  calcium       Float?
  iron          Float?
  vitaminA      Float?
  vitaminB1     Float?
  vitaminB2     Float?
  vitaminC      Float?
  sourceUrl     String?
  source        String   @default("FNRI")
  scrapedAt     DateTime @default(now())
}

model ScrapingLog {
  id            Int       @id @default(autoincrement())
  type          String
  status        String
  itemsScraped  Int       @default(0)
  message       String?   @db.Text
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
}
